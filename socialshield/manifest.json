{
  "manifest_version": 3,
  "name": "SocialShield",
  "version": "1.0.0",
  "description": "Social Media Security & Connection Monitor - Giám sát bảo mật và theo dõi biến động kết nối trên mạng xã hội",
  "permissions": [
    "storage",
    "activeTab",
    "notifications",
    "alarms",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://safebrowsing.googleapis.com/*",
    "https://www.virustotal.com/*",
    "https://urlhaus-api.abuse.ch/*",
    "https://haveibeenpwned.com/*",
    "https://api.pwnedpasswords.com/*",
    "https://api.xposedornot.com/*",
    "https://hackcheck.woventeams.com/*",
    "https://api.github.com/*",
    "https://www.reddit.com/*",
    "https://gitlab.com/*",
    "https://codeberg.org/*",
    "https://hacker-news.firebaseio.com/*",
    "https://dev.to/*",
    "https://keybase.io/*",
    "https://registry.npmjs.com/*",
    "https://hub.docker.com/*",
    "https://en.wikipedia.org/*",
    "https://mastodon.social/*",
    "https://public.api.bsky.app/*",
    "https://lichess.org/*",
    "https://api.chess.com/*",
    "https://codeforces.com/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["lib/storage.js", "lib/diff.js", "lib/scanner.js", "lib/text-analyzer.js", "lib/privacy-auditor.js", "lib/image-analyzer.js", "content/instagram.js"],
      "css": ["content/instagram.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["lib/storage.js", "lib/diff.js", "lib/scanner.js", "lib/text-analyzer.js", "lib/privacy-auditor.js", "lib/image-analyzer.js", "content/twitter.js"],
      "css": ["content/twitter.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SocialShield"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
